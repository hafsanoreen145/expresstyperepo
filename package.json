{
  "name": "expressjs-oauth-linkedin",
  "version": "1.0.0",
  "description": "Express.js TypeScript boilerplate with LinkedIn OAuth and Prisma",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "express",
    "typescript",
    "oauth",
    "linkedin",
    "prisma"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "5.21.1",
    "axios": "latest",
    "cookie-parser": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-session": "latest",
    "joi": "^18.2.1",
    "jsonwebtoken": "latest"
  },
  "devDependencies": {
    "@types/cookie-parser": "latest",
    "@types/express": "latest",
    "@types/express-session": "latest",
    "@types/joi": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/node": "latest",
    "prisma": "5.21.1",
    "ts-node": "latest",
    "ts-node-dev": "latest",
    "typescript": "latest"
  }
}
